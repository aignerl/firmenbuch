extends layout

block content
  if !firma
    p Keine Daten gefunden.
  else
    h1= firma.namen.join(' ') || firma.fnr

    table.kv-table
      thead
        tr
          th Eigenschaft
          th Wert
      tbody
        tr
          th FNR
          td= firma.fnr
        tr
          th Stichtag
          td= firma.stichtag
        tr
          th Umfang
          td= firma.umfang
        tr
          th Sitz
          td= firma.sitz
        tr
          th Rechtsform
          td= firma.rechtsform
        each a in firma.adressen
          tr
            th Adresse
            td.address
              if a.strasse
                | #{a.strasse} #{a.hausnummer}
                br
              | #{a.plz} #{a.ort}
              if a.staat && a.staat !== 'AUT'
                |  (#{a.staat})

    if firma.funktionen.length > 0
      h2 Funktionen
      table
        thead
          tr
            th Funktion
            th Name
        tbody
          each f in firma.funktionen
            tr(class=f.fnr ? 'row-link' : '' onclick=f.fnr ? "window.location='/firma/" + f.fnr + "'" : undefined)
              td= f.fkentext
              td
                | #{f.name}
                if f.quelle === 'EVI'
                  |
                  a.source-badge(href="https://www.evi.gv.at/f/" + firma.fnr.replace(/ /g, '') target="_blank" rel="noopener" onclick="event.stopPropagation()" data-tooltip="Auf evi.gv.at öffnen") EVI

    if xmlUrkunden && xmlUrkunden.length > 0
      h2 Kennzahlen
      div.kpi-section
        div.kpi-year-selector
          label(for="kpi-year") Geschäftsjahr
          select#kpi-year
            each u in xmlUrkunden
              option(value=u.key)= u.label
        div#kpi-cards
          p.kpi-loading Lade Kennzahlen…

    h2 Organigramm
      span.info-badge(data-tooltip="Zeigt Gesellschafter rekursiv nach oben (Quelle: evi.gv.at). Beteiligungen nach unten (Tochtergesellschaften) sind über die verfügbaren APIs nicht abrufbar und daher nicht dargestellt. Die Daten können unvollständig sein.") ?
    div#org-chart.org-chart

    if urkunden && urkunden.length > 0
      h2 Urkunden
      div.urkunden-scroll
        table#urkunden-table
          thead
            tr
              th.sortable(data-col="0") Stichtag / Datum
              th.sortable(data-col="1") Dokumentart
              th.sortable(data-col="2") Eingereicht
              th.sortable(data-col="3") Typ
              th.sortable(data-col="4") Größe
              th
          tbody
            each u in urkunden
              tr.row-link(onclick="if(!event.target.closest('a'))this.querySelector('a.btn').click()")
                td(data-sort=u.datumSort)= u.stichtag || u.dokumentendatum || '—'
                td
                  | #{u.dokumentart || '—'}
                  if u.bemerkung
                    br
                    small= u.bemerkung
                td(data-sort=u.eingereicht)= u.eingereicht || '—'
                td
                  span.badge(class=u.dateiendung === 'pdf' ? 'badge--active' : 'badge--history')
                    = u.dateiendung.toUpperCase()
                td(data-sort=u.groesse)= u.groesseFormatiert || '—'
                td
                  a.btn(href=`/urkunde/download?key=${encodeURIComponent(u.key)}` target="_blank") Öffnen

  a.back-fab(href="/" data-tooltip="Zurück zur Suche")
    svg(xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round")
      polyline(points="15 18 9 12 15 6")

  script.
    (function () {
      var table = document.getElementById('urkunden-table');
      if (!table) return;

      var sortCol = 0;
      var sortDir = -1; // -1 = descending, 1 = ascending

      var headers = table.querySelectorAll('thead th.sortable');

      function sortTable(col, dir) {
        var tbody = table.querySelector('tbody');
        var rows = Array.from(tbody.querySelectorAll('tr'));

        rows.sort(function (a, b) {
          var aVal = a.cells[col].dataset.sort !== undefined
            ? a.cells[col].dataset.sort
            : a.cells[col].textContent.trim();
          var bVal = b.cells[col].dataset.sort !== undefined
            ? b.cells[col].dataset.sort
            : b.cells[col].textContent.trim();

          var aNum = parseFloat(aVal);
          var bNum = parseFloat(bVal);
          if (!isNaN(aNum) && !isNaN(bNum)) return (aNum - bNum) * dir;

          if (aVal < bVal) return -1 * dir;
          if (aVal > bVal) return 1 * dir;
          return 0;
        });

        rows.forEach(function (r) { tbody.appendChild(r); });

        headers.forEach(function (h) { h.classList.remove('sort-asc', 'sort-desc'); });
        headers[col].classList.add(dir === 1 ? 'sort-asc' : 'sort-desc');
      }

      headers.forEach(function (th, i) {
        th.addEventListener('click', function () {
          if (sortCol === i) {
            sortDir *= -1;
          } else {
            sortCol = i;
            sortDir = -1;
          }
          sortTable(sortCol, sortDir);
        });
      });

      // initial sort: Stichtag descending
      sortTable(0, -1);

      // set scroll container height to exactly 7 full rows
      var wrapper = table.closest('.urkunden-scroll');
      if (wrapper) {
        var rows = Array.from(table.querySelectorAll('tbody tr'));
        var h = table.querySelector('thead').offsetHeight;
        for (var i = 0; i < Math.min(7, rows.length); i++) {
          h += rows[i].offsetHeight;
        }
        wrapper.style.maxHeight = h + 'px';
      }
    })();

  script.
    (function () {
      var yearSelect = document.getElementById('kpi-year');
      var kpiCards  = document.getElementById('kpi-cards');
      if (!yearSelect || !kpiCards) return;

      var fnrNorm = !{JSON.stringify(firma ? firma.fnr.replace(/ /g, '') : '')};

      function fmt(v, type) {
        if (v === null || v === undefined) return '\u2014';
        if (type === 'pct') return v.toFixed(1).replace('.', ',') + '\u202f%';
        var abs = Math.abs(v);
        var s;
        if (abs >= 1e9) s = (v / 1e9).toFixed(1).replace('.', ',') + '\u202fMrd.\u202f\u20ac';
        else if (abs >= 1e6) s = (v / 1e6).toFixed(1).replace('.', ',') + '\u202fMio.\u202f\u20ac';
        else if (abs >= 1e3) s = Math.round(v / 1e3).toLocaleString('de-AT') + '\u202fTsd.\u202f\u20ac';
        else s = Math.round(v).toLocaleString('de-AT') + '\u202f\u20ac';
        return s;
      }

      function escAttr(s) {
        return String(s).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/\n/g, '&#10;');
      }

      function ev(kpi) { return kpi && kpi.betrag != null ? fmt(kpi.betrag, 'eur') : null; }

      function renderKpis(data) {
        if (data.error) {
          kpiCards.innerHTML = '<p class="kpi-error">Kennzahlen konnten nicht geladen werden.</p>';
          return;
        }
        var kpis = data.kpis || {};
        var D = '\u00f7', X = '\u00d7', GE = '\u2265', NB = '\u202f';
        var cards = [
          { label: 'Bilanzsumme', key: 'bilanzsumme', type: 'eur',
            tip: function(k) { return 'Aktiva gesamt\nSumme aller Verm\u00f6gensgegen-\nst\u00e4nde der Bilanz'; } },
          { label: 'Anlageverm\u00f6gen', key: 'anlageverm\u00f6gen', type: 'eur',
            tip: function(k) { return 'Langfristig gebundenes Verm\u00f6gen\n(Sachanlagen, immaterielle Anlagen,\nFinanzanlagen)'; } },
          { label: 'Umlaufverm\u00f6gen', key: 'umlaufverm\u00f6gen', type: 'eur',
            tip: function(k) { return 'Kurzfristig verf\u00fcgbares Verm\u00f6gen\n(Vorr\u00e4te, Forderungen, fl\u00fcssige Mittel)'; } },
          { label: 'Eigenkapital', key: 'eigenkapital', type: 'eur',
            tip: function(k) { return 'Stamm-/Grundkapital\n+ R\u00fccklagen\n+ Bilanzgewinn/-verlust'; } },
          { label: 'EK-Quote', key: 'ekQuote', type: 'pct',
            tip: function(k) {
              var l = 'Eigenkapital ' + D + ' Bilanzsumme ' + X + ' 100';
              var ek = ev(k.eigenkapital), bs = ev(k.bilanzsumme);
              if (ek && bs) l += '\n= ' + ek + ' ' + D + ' ' + bs + ' ' + X + ' 100';
              return l;
            } },
          { label: 'Anlageintensit\u00e4t', key: 'anlageintensit\u00e4t', type: 'pct',
            tip: function(k) {
              var l = 'Anlageverm\u00f6gen ' + D + ' Bilanzsumme ' + X + ' 100';
              var av = ev(k['anlageverm\u00f6gen']), bs = ev(k.bilanzsumme);
              if (av && bs) l += '\n= ' + av + ' ' + D + ' ' + bs + ' ' + X + ' 100';
              return l;
            } },
          { label: 'Verbindlichkeiten', key: 'verbindlichkeiten', type: 'eur',
            tip: function(k) { return 'Verbindlichkeiten gesamt\n(kurz- und langfristig)'; } },
          { label: 'Verschuldungsgrad', key: 'verschuldungsgrad', type: 'pct',
            tip: function(k) {
              var l = 'Verbindlichkeiten ' + D + ' Eigenkapital ' + X + ' 100';
              var vb = ev(k.verbindlichkeiten), ek = ev(k.eigenkapital);
              if (vb && ek) l += '\n= ' + vb + ' ' + D + ' ' + ek + ' ' + X + ' 100';
              return l;
            } },
          { label: 'Liquidit\u00e4t 1', key: 'liquidit\u00e4t1', type: 'pct',
            tip: function(k) {
              var l = 'Fl\u00fcssige Mittel ' + D + ' kurzfristige Verbindlichkeiten ' + X + ' 100';
              var fm = ev(k['fl\u00fcssigeMittel']), kv = ev(k['kurzfristigeVerbindlichkeiten']);
              if (fm && kv) l += '\n= ' + fm + ' ' + D + ' ' + kv + ' ' + X + ' 100';
              l += '\nRichtwert: ' + GE + ' 20' + NB + '%';
              return l;
            } },
          { label: 'Liquidit\u00e4t 2', key: 'liquidit\u00e4t2', type: 'pct',
            tip: function(k) {
              var l = '(Fl\u00fcssige Mittel + Forderungen) ' + D + ' kurzfristige Verbindlichkeiten ' + X + ' 100';
              var fm = ev(k['fl\u00fcssigeMittel']), fo = ev(k.forderungen), kv = ev(k['kurzfristigeVerbindlichkeiten']);
              if (fm && fo && kv) l += '\n= (' + fm + ' + ' + fo + ') ' + D + ' ' + kv + ' ' + X + ' 100';
              l += '\nRichtwert: ' + GE + ' 100' + NB + '%';
              return l;
            } },
          { label: 'Liquidit\u00e4t 3', key: 'liquidit\u00e4t3', type: 'pct',
            tip: function(k) {
              var l = 'Umlaufverm\u00f6gen ' + D + ' kurzfristige Verbindlichkeiten ' + X + ' 100';
              var uv = ev(k['umlaufverm\u00f6gen']), kv = ev(k['kurzfristigeVerbindlichkeiten']);
              if (uv && kv) l += '\n= ' + uv + ' ' + D + ' ' + kv + ' ' + X + ' 100';
              l += '\nRichtwert: ' + GE + ' 120' + NB + '%';
              return l;
            } },
          { label: 'Umsatz', key: 'umsatz', type: 'eur',
            tip: function(k) { return 'Umsatzerlöse (Netto, exkl. MwSt.)'; } },
          { label: 'Personalaufwand', key: 'personalaufwand', type: 'eur',
            tip: function(k) { return 'L\u00f6hne + Geh\u00e4lter + Sozialaufwand\n(negativer Wert = Aufwand)'; } },
          { label: 'Abschreibungen', key: 'abschreibungen', type: 'eur',
            tip: function(k) { return 'Abschreibungen auf Sachanlagen\nund immaterielle Anlagen\n(negativer Wert = Aufwand)'; } },
          { label: 'Betriebsergebnis', key: 'betriebsergebnis', type: 'eur',
            tip: function(k) { return 'Betriebsergebnis (EBIT)\nErgebnis aus dem operativen Gesch\u00e4ft'; } },
          { label: 'EGT', key: 'egt', type: 'eur',
            tip: function(k) { return 'Ergebnis der gew\u00f6hnlichen Gesch\u00e4ftst\u00e4tigkeit\nBetriebsergebnis + Finanzergebnis'; } },
          { label: 'Jahresergebnis', key: 'jahresergebnis', type: 'eur',
            tip: function(k) { return 'Jahres\u00fcberschuss / -fehlbetrag\nNach au\u00dferordentlichen Posten und Steuern'; } },
          { label: 'Umsatzrendite', key: 'umsatzrendite', type: 'pct',
            tip: function(k) {
              var l = 'Jahresergebnis ' + D + ' Umsatz ' + X + ' 100';
              var je = ev(k.jahresergebnis), u = ev(k.umsatz);
              if (je && u) l += '\n= ' + je + ' ' + D + ' ' + u + ' ' + X + ' 100';
              return l;
            } },
          { label: 'ROE', key: 'roe', type: 'pct',
            tip: function(k) {
              var l = 'Eigenkapitalrendite\nJahresergebnis ' + D + ' Eigenkapital ' + X + ' 100';
              var je = ev(k.jahresergebnis), ek = ev(k.eigenkapital);
              if (je && ek) l += '\n= ' + je + ' ' + D + ' ' + ek + ' ' + X + ' 100';
              return l;
            } },
          { label: 'ROA', key: 'roa', type: 'pct',
            tip: function(k) {
              var l = 'Gesamtkapitalrendite\nJahresergebnis ' + D + ' Bilanzsumme ' + X + ' 100';
              var je = ev(k.jahresergebnis), bs = ev(k.bilanzsumme);
              if (je && bs) l += '\n= ' + je + ' ' + D + ' ' + bs + ' ' + X + ' 100';
              return l;
            } },
        ];

        var html = '<div class="kpi-grid">';
        cards.forEach(function (c) {
          var kpi = kpis[c.key];
          if (!kpi || (kpi.betrag === null && kpi.betragVJ === null)) return;
          var tip = c.tip ? escAttr(c.tip(kpis)) : '';
          html += '<div class="kpi-card">';
          html += '<div class="kpi-card-header">';
          html += '<div class="kpi-label">' + c.label + '</div>';
          if (tip) html += '<span class="info-badge kpi-tip" data-tooltip="' + tip + '">?</span>';
          html += '</div>';
          html += '<div class="kpi-value">' + fmt(kpi.betrag, c.type) + '</div>';
          if (kpi.betragVJ !== null && kpi.betragVJ !== undefined) {
            html += '<div class="kpi-vj">VJ\u202f' + fmt(kpi.betragVJ, c.type) + '</div>';
          }
          html += '</div>';
        });
        html += '</div>';

        if (html === '<div class="kpi-grid"></div>') {
          html = '<p class="kpi-error">Keine Kennzahlen verf\u00fcgbar.</p>';
        }
        kpiCards.innerHTML = html;
      }

      function loadKpis(key) {
        kpiCards.innerHTML = '<p class="kpi-loading">Lade Kennzahlen\u2026</p>';
        fetch('/api/firma/' + encodeURIComponent(fnrNorm) + '/jahresabschluss?key=' + encodeURIComponent(key))
          .then(function (r) { return r.json(); })
          .then(renderKpis)
          .catch(function () {
            kpiCards.innerHTML = '<p class="kpi-error">Kennzahlen konnten nicht geladen werden.</p>';
          });
      }

      yearSelect.addEventListener('change', function () { loadKpis(yearSelect.value); });
      if (yearSelect.value) loadKpis(yearSelect.value);
    })();

block scripts
  script(src="https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js")
  script.
    (function () {
      var fnr = !{JSON.stringify(firma ? firma.fnr.replace(/ /g, '') : '')};
      var container = document.getElementById('org-chart');
      if (!container || !fnr) return;

      container.innerHTML = '<p class="org-loading">Lade Organigramm\u2026</p>';

      fetch('/api/firma/' + encodeURIComponent(fnr) + '/baum')
        .then(function (r) { return r.json(); })
        .then(function (data) { renderTree(data); })
        .catch(function () {
          container.innerHTML = '<p class="org-error">Organigramm konnte nicht geladen werden.</p>';
        });

      function renderTree(data) {
        container.innerHTML = '';

        var PAD = 16;
        var STD_W = 180, NODE_H = 44, MIN_W = 90;
        var H_GAP = 24, V_GAP = 70;
        var containerW = container.clientWidth - PAD * 2;

        var root = d3.hierarchy(data);

        // Max nodes at any single depth level
        var levelCounts = {};
        root.each(function (d) { levelCounts[d.depth] = (levelCounts[d.depth] || 0) + 1; });
        var maxBreadth = Math.max.apply(null, Object.keys(levelCounts).map(function (k) { return levelCounts[k]; }));

        // Decide layout mode
        var nodeW = STD_W;
        var stacked = false;
        var neededW = maxBreadth * (STD_W + H_GAP) - H_GAP;
        if (neededW > containerW) {
          nodeW = Math.floor((containerW + H_GAP) / maxBreadth) - H_GAP;
          if (nodeW < MIN_W) { nodeW = STD_W; stacked = true; }
        }
        var maxChars = Math.max(8, Math.floor(nodeW / 7.5));

        var tooltip = d3.select(container).append('div').attr('class', 'org-tooltip');

        // Zoom hint: shown briefly when scrolling without Ctrl
        var zoomHint = d3.select(container).append('div').attr('class', 'org-zoom-hint')
          .text('Strg + Scrollen zum Zoomen');
        var hintTimer;
        container.addEventListener('wheel', function (e) {
          if (!e.ctrlKey) {
            zoomHint.classed('org-zoom-hint--visible', true);
            clearTimeout(hintTimer);
            hintTimer = setTimeout(function () { zoomHint.classed('org-zoom-hint--visible', false); }, 1500);
          }
        }, { passive: true });

        // Shared hover helper for GF / Vorstand tooltip
        function attachHover(sel, gf, vs) {
          if (!((gf && gf.length) || (vs && vs.length))) return;
          sel.on('mouseover', function (event) {
            var parts = [];
            if (gf && gf.length) parts.push('<strong>Gesch\u00e4ftsf\u00fchrung</strong><br>' + gf.join('<br>'));
            if (vs && vs.length) parts.push('<strong>Vorstand</strong><br>' + vs.join('<br>'));
            tooltip.html(parts.join('<br><br>')).classed('org-tooltip--visible', true);
          })
          .on('mousemove', function (event) {
            var rect = container.getBoundingClientRect();
            tooltip.style('left', (event.clientX - rect.left + 14) + 'px')
                   .style('top',  (event.clientY - rect.top  - 10) + 'px');
          })
          .on('mouseout', function () { tooltip.classed('org-tooltip--visible', false); });
        }

        if (!stacked) {
          // ── Normal layout: root at bottom, shareholders fanning upward ──
          d3.tree().nodeSize([nodeW + H_GAP, NODE_H + V_GAP])(root);
          root.each(function (d) { d.y = -d.y; });

          var nodes = root.descendants();
          var xs = nodes.map(function (d) { return d.x; });
          var ys = nodes.map(function (d) { return d.y; });
          var minX = Math.min.apply(null, xs), maxX = Math.max.apply(null, xs);
          var minY = Math.min.apply(null, ys), maxY = Math.max.apply(null, ys);

          var svgW = Math.max(maxX - minX + nodeW + PAD * 2, containerW);
          var svgH = maxY - minY + NODE_H + PAD * 2;
          var offsetX = -minX + (svgW - (maxX - minX + nodeW)) / 2;
          var offsetY = -minY + PAD + NODE_H / 2;

          var svg = d3.select(container).append('svg').attr('width', svgW).attr('height', svgH);
          var zoomG = svg.append('g');
          var g = zoomG.append('g').attr('transform', 'translate(' + offsetX + ',' + offsetY + ')');

          g.selectAll('.org-link').data(root.links()).join('path').attr('class', 'org-link')
            .attr('d', d3.linkVertical().x(function (n) { return n.x; }).y(function (n) { return n.y; }));

          drawNodes(g, nodes,
            function (d) { return d.x; },
            function (d) { return d.y; },
            nodeW, tooltip);

          // ── Extra nodes: Töchter (below root) + co-owners & sisters (right of tree) ──
          var extraLink = d3.linkVertical().x(function (n) { return n.x; }).y(function (n) { return n.y; });

          var rendered = new Set();
          nodes.forEach(function (d) { if (d.data.fnr) rendered.add(d.data.fnr); });

          // Töchter of root → centered below
          var tochter = (data.tochter || []).filter(function (t) { return t.fnr && !rendered.has(t.fnr); });
          var tochterY = 0;
          if (tochter.length > 0) {
            tochterY = NODE_H + V_GAP;
            svg.attr('height', svgH + V_GAP + NODE_H);
            var totalSubW = tochter.length * (nodeW + H_GAP) - H_GAP;
            var subStartX = root.x - totalSubW / 2;
            tochter.forEach(function (t, i) {
              rendered.add(t.fnr);
              var tx = subStartX + i * (nodeW + H_GAP) + nodeW / 2;
              g.append('path').attr('class', 'org-link')
                .attr('d', extraLink({ source: { x: root.x, y: NODE_H / 2 }, target: { x: tx, y: tochterY - NODE_H / 2 } }));
              var nG = g.append('g').attr('class', 'org-node org-node--firma')
                .attr('transform', 'translate(' + tx + ',' + tochterY + ')');
              nG.style('cursor', 'pointer').on('click', function () { window.location = '/firma/' + t.fnr; });
              nG.append('rect').attr('x', -nodeW / 2).attr('y', -NODE_H / 2).attr('width', nodeW).attr('height', NODE_H).attr('rx', 6);
              nG.append('text').attr('text-anchor', 'middle').attr('dy', '0.35em')
                .text(t.name.length > maxChars ? t.name.slice(0, maxChars - 1) + '\u2026' : t.name);
              attachHover(nG, t.geschaeftsfuehrer, t.vorstand);
            });
          }

          // Co-owners + sisters → to the right of the tree
          var treeMaxX = Math.max.apply(null, nodes.map(function (d) { return d.x; })) + nodeW / 2;
          var nextExtraX = treeMaxX + H_GAP;
          var maxExtraX = treeMaxX;

          // Co-owners of each Tochter (placed at root Y level, linked down to Tochter node)
          var coSubW = tochter.length * (nodeW + H_GAP) - H_GAP;
          var coSubSX = root.x - coSubW / 2;
          tochter.forEach(function (t, i) {
            var tochterNodeX = coSubSX + i * (nodeW + H_GAP) + nodeW / 2;
            (t.coGesellschafter || []).forEach(function (cg) {
              if (rendered.has(cg.fnr)) return;
              rendered.add(cg.fnr);
              var cgx = nextExtraX + nodeW / 2;
              nextExtraX += nodeW + H_GAP;
              maxExtraX = Math.max(maxExtraX, cgx + nodeW / 2);
              g.append('path').attr('class', 'org-link')
                .attr('d', extraLink({ source: { x: cgx, y: NODE_H / 2 }, target: { x: tochterNodeX, y: tochterY - NODE_H / 2 } }));
              var cgG = g.append('g').attr('class', 'org-node org-node--firma')
                .attr('transform', 'translate(' + cgx + ',0)');
              cgG.style('cursor', 'pointer').on('click', function () { window.location = '/firma/' + cg.fnr; });
              cgG.append('rect').attr('x', -nodeW / 2).attr('y', -NODE_H / 2).attr('width', nodeW).attr('height', NODE_H).attr('rx', 6);
              cgG.append('text').attr('text-anchor', 'middle').attr('dy', '0.35em')
                .text(cg.name.length > maxChars ? cg.name.slice(0, maxChars - 1) + '\u2026' : cg.name);
              attachHover(cgG, cg.geschaeftsfuehrer, cg.vorstand);
            });
          });

          // Sisters: other Töchter of each Gesellschafter in the tree
          nodes.filter(function (d) { return d.depth > 0 && d.data.type === 'firma'; })
            .forEach(function (d) {
              (d.data.tochter || []).forEach(function (s) {
                if (!s.fnr || rendered.has(s.fnr)) return;
                rendered.add(s.fnr);
                var sibY = d.y + NODE_H + V_GAP;
                var sx = nextExtraX + nodeW / 2;
                nextExtraX += nodeW + H_GAP;
                maxExtraX = Math.max(maxExtraX, sx + nodeW / 2);
                g.append('path').attr('class', 'org-link')
                  .attr('d', extraLink({ source: { x: d.x, y: d.y + NODE_H / 2 }, target: { x: sx, y: sibY - NODE_H / 2 } }));
                var nG = g.append('g').attr('class', 'org-node org-node--firma')
                  .attr('transform', 'translate(' + sx + ',' + sibY + ')');
                nG.style('cursor', 'pointer').on('click', function () { window.location = '/firma/' + s.fnr; });
                nG.append('rect').attr('x', -nodeW / 2).attr('y', -NODE_H / 2).attr('width', nodeW).attr('height', NODE_H).attr('rx', 6);
                nG.append('text').attr('text-anchor', 'middle').attr('dy', '0.35em')
                  .text(s.name.length > maxChars ? s.name.slice(0, maxChars - 1) + '\u2026' : s.name);
                attachHover(nG, s.geschaeftsfuehrer, s.vorstand);
              });
            });

          if (maxExtraX + offsetX + PAD > svgW) {
            svg.attr('width', maxExtraX + offsetX + PAD);
          }

          svg.call(d3.zoom()
            .filter(function (event) { return event.type === 'wheel' ? event.ctrlKey : true; })
            .scaleExtent([0.25, 4])
            .on('zoom', function (event) { zoomG.attr('transform', event.transform); }));

        } else {
          // ── Stacked layout: root on right, shareholders stacked left ──
          var LEVEL_W = STD_W + H_GAP;
          var ROW_H   = NODE_H + 28;

          d3.tree().nodeSize([ROW_H, LEVEL_W])(root);

          var nodes = root.descendants();
          var xs = nodes.map(function (d) { return d.x; });
          var minX = Math.min.apply(null, xs), maxX = Math.max.apply(null, xs);

          var svgH = maxX - minX + NODE_H + PAD * 2;
          var svgW = Math.max((root.height + 1) * LEVEL_W + PAD * 2, containerW);
          var rightEdge = svgW - PAD;

          function gx(d) { return rightEdge - d.y - STD_W / 2; }
          function gy(d) { return d.x - minX + PAD + NODE_H / 2; }

          var svg = d3.select(container).append('svg').attr('width', svgW).attr('height', svgH);
          var zoomG = svg.append('g');
          var g = zoomG.append('g');

          g.selectAll('.org-link').data(root.links()).join('path').attr('class', 'org-link')
            .attr('d', d3.linkHorizontal().x(function (n) { return gx(n); }).y(function (n) { return gy(n); }));

          drawNodes(g, nodes, gx, gy, STD_W, tooltip);

          svg.call(d3.zoom()
            .filter(function (event) { return event.type === 'wheel' ? event.ctrlKey : true; })
            .scaleExtent([0.25, 4])
            .on('zoom', function (event) { zoomG.attr('transform', event.transform); }));
        }

        function drawNodes(g, nodes, getX, getY, nW, tooltip) {
          var node = g.selectAll('.org-node')
            .data(nodes).join('g')
            .attr('class', function (d) {
              var cls = 'org-node org-node--' + d.data.type;
              if (d.data.fnr === fnr) cls += ' org-node--current';
              return cls;
            })
            .attr('transform', function (d) { return 'translate(' + getX(d) + ',' + getY(d) + ')'; });

          node.append('rect')
            .attr('x', -nW / 2).attr('y', -NODE_H / 2)
            .attr('width', nW).attr('height', NODE_H).attr('rx', 6);

          node.append('text')
            .attr('text-anchor', 'middle').attr('dy', '0.35em')
            .text(function (d) {
              var n = d.data.name;
              return n.length > maxChars ? n.slice(0, maxChars - 1) + '\u2026' : n;
            });

          // Hover: Geschäftsführer / Vorstand
          node.filter(function (d) {
            return d.data.type === 'firma' && (
              (d.data.geschaeftsfuehrer && d.data.geschaeftsfuehrer.length > 0) ||
              (d.data.vorstand && d.data.vorstand.length > 0));
          }).each(function (d) {
            attachHover(d3.select(this), d.data.geschaeftsfuehrer, d.data.vorstand);
          });

          // Click: navigate
          node.filter(function (d) { return d.data.type === 'firma' && d.data.fnr && d.data.fnr !== fnr; })
            .style('cursor', 'pointer')
            .on('click', function (event, d) { window.location = '/firma/' + d.data.fnr; });
        }
      }
    })();
