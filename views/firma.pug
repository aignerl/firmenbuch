extends layout

block content
  if !firma
    p Keine Daten gefunden.
  else
    h1= firma.namen.join(' ') || firma.fnr

    table.kv-table
      thead
        tr
          th Eigenschaft
          th Wert
      tbody
        tr
          th FNR
          td= firma.fnr
        tr
          th Stichtag
          td= firma.stichtag
        tr
          th Umfang
          td= firma.umfang
        tr
          th Sitz
          td= firma.sitz
        tr
          th Rechtsform
          td= firma.rechtsform
        each a in firma.adressen
          tr
            th Adresse
            td.address
              if a.strasse
                | #{a.strasse} #{a.hausnummer}
                br
              | #{a.plz} #{a.ort}
              if a.staat && a.staat !== 'AUT'
                |  (#{a.staat})

    if firma.funktionen.length > 0
      h2 Funktionen
      table
        thead
          tr
            th Funktion
            th Name
        tbody
          each f in firma.funktionen
            tr(class=f.fnr ? 'row-link' : '' onclick=f.fnr ? "window.location='/firma/" + f.fnr + "'" : undefined)
              td= f.fkentext
              td
                | #{f.name}
                if f.quelle === 'EVI'
                  |
                  a.source-badge(href="https://www.evi.gv.at/f/" + firma.fnr.replace(/ /g, '') target="_blank" rel="noopener" onclick="event.stopPropagation()" data-tooltip="Auf evi.gv.at öffnen") EVI

    if urkunden && urkunden.length > 0
      h2 Urkunden
      div.urkunden-scroll
        table#urkunden-table
          thead
            tr
              th.sortable(data-col="0") Stichtag / Datum
              th.sortable(data-col="1") Dokumentart
              th.sortable(data-col="2") Eingereicht
              th.sortable(data-col="3") Typ
              th.sortable(data-col="4") Größe
              th
          tbody
            each u in urkunden
              tr
                td(data-sort=u.datumSort)= u.stichtag || u.dokumentendatum || '—'
                td
                  | #{u.dokumentart || '—'}
                  if u.bemerkung
                    br
                    small= u.bemerkung
                td(data-sort=u.eingereicht)= u.eingereicht || '—'
                td
                  span.badge(class=u.dateiendung === 'pdf' ? 'badge--active' : 'badge--history')
                    = u.dateiendung.toUpperCase()
                td(data-sort=u.groesse)= u.groesseFormatiert || '—'
                td
                  a.btn(href=`/urkunde/download?key=${encodeURIComponent(u.key)}` target="_blank") Öffnen

    h2 Organigramm
    div#org-chart.org-chart

  a.back-link(href="/") ← Neue Suche

  script.
    (function () {
      var table = document.getElementById('urkunden-table');
      if (!table) return;

      var sortCol = 0;
      var sortDir = -1; // -1 = descending, 1 = ascending

      var headers = table.querySelectorAll('thead th.sortable');

      function sortTable(col, dir) {
        var tbody = table.querySelector('tbody');
        var rows = Array.from(tbody.querySelectorAll('tr'));

        rows.sort(function (a, b) {
          var aVal = a.cells[col].dataset.sort !== undefined
            ? a.cells[col].dataset.sort
            : a.cells[col].textContent.trim();
          var bVal = b.cells[col].dataset.sort !== undefined
            ? b.cells[col].dataset.sort
            : b.cells[col].textContent.trim();

          var aNum = parseFloat(aVal);
          var bNum = parseFloat(bVal);
          if (!isNaN(aNum) && !isNaN(bNum)) return (aNum - bNum) * dir;

          if (aVal < bVal) return -1 * dir;
          if (aVal > bVal) return 1 * dir;
          return 0;
        });

        rows.forEach(function (r) { tbody.appendChild(r); });

        headers.forEach(function (h) { h.classList.remove('sort-asc', 'sort-desc'); });
        headers[col].classList.add(dir === 1 ? 'sort-asc' : 'sort-desc');
      }

      headers.forEach(function (th, i) {
        th.addEventListener('click', function () {
          if (sortCol === i) {
            sortDir *= -1;
          } else {
            sortCol = i;
            sortDir = -1;
          }
          sortTable(sortCol, sortDir);
        });
      });

      // initial sort: Stichtag descending
      sortTable(0, -1);

      // set scroll container height to exactly 7 full rows
      var wrapper = table.closest('.urkunden-scroll');
      if (wrapper) {
        var rows = Array.from(table.querySelectorAll('tbody tr'));
        var h = table.querySelector('thead').offsetHeight;
        for (var i = 0; i < Math.min(7, rows.length); i++) {
          h += rows[i].offsetHeight;
        }
        wrapper.style.maxHeight = h + 'px';
      }
    })();

block scripts
  script(src="https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js")
  script.
    (function () {
      var fnr = !{JSON.stringify(firma ? firma.fnr.replace(/ /g, '') : '')};
      var container = document.getElementById('org-chart');
      if (!container || !fnr) return;

      container.innerHTML = '<p class="org-loading">Lade Organigramm\u2026</p>';

      fetch('/api/firma/' + encodeURIComponent(fnr) + '/baum')
        .then(function (r) { return r.json(); })
        .then(function (data) { renderTree(data); })
        .catch(function () {
          container.innerHTML = '<p class="org-error">Organigramm konnte nicht geladen werden.</p>';
        });

      function renderTree(data) {
        container.innerHTML = '';

        var NODE_W = 190, NODE_H = 44, H_GAP = 30, V_GAP = 70;

        var root = d3.hierarchy(data);
        d3.tree().nodeSize([NODE_W + H_GAP, NODE_H + V_GAP])(root);

        // Flip vertically: root at bottom, shareholders going up
        root.each(function (d) { d.y = -d.y; });

        var nodes = root.descendants();
        var xs = nodes.map(function (d) { return d.x; });
        var ys = nodes.map(function (d) { return d.y; });
        var minX = Math.min.apply(null, xs);
        var maxX = Math.max.apply(null, xs);
        var minY = Math.min.apply(null, ys);
        var maxY = Math.max.apply(null, ys);

        var pad = 16;
        var svgW = Math.max(maxX - minX + NODE_W + pad * 2, container.offsetWidth);
        var svgH = maxY - minY + NODE_H + pad * 2;
        var offsetX = -minX + (svgW - (maxX - minX + NODE_W)) / 2;
        var offsetY = -minY + pad;

        var svg = d3.select(container).append('svg')
          .attr('width', svgW)
          .attr('height', svgH);

        var g = svg.append('g')
          .attr('transform', 'translate(' + offsetX + ',' + offsetY + ')');

        // Links
        g.selectAll('.org-link')
          .data(root.links())
          .join('path')
          .attr('class', 'org-link')
          .attr('d', function (d) {
            return d3.linkVertical()
              .x(function (n) { return n.x; })
              .y(function (n) { return n.y; })(d);
          });

        // Tooltip
        var tooltip = d3.select(container).append('div')
          .attr('class', 'org-tooltip');

        // Node groups
        var node = g.selectAll('.org-node')
          .data(nodes)
          .join('g')
          .attr('class', function (d) {
            var cls = 'org-node org-node--' + d.data.type;
            if (d.data.fnr === fnr) cls += ' org-node--current';
            return cls;
          })
          .attr('transform', function (d) {
            return 'translate(' + d.x + ',' + d.y + ')';
          });

        // Box
        node.append('rect')
          .attr('x', -NODE_W / 2)
          .attr('y', -NODE_H / 2)
          .attr('width', NODE_W)
          .attr('height', NODE_H)
          .attr('rx', 6);

        // Label
        node.append('text')
          .attr('text-anchor', 'middle')
          .attr('dy', '0.35em')
          .text(function (d) {
            var n = d.data.name;
            return n.length > 26 ? n.slice(0, 25) + '\u2026' : n;
          });

        // Hover: show Geschäftsführer
        node.filter(function (d) {
          return d.data.type === 'firma' && d.data.geschaeftsfuehrer && d.data.geschaeftsfuehrer.length > 0;
        })
          .on('mouseover', function (event, d) {
            tooltip
              .html('<strong>Gesch\u00e4ftsf\u00fchrung</strong><br>' + d.data.geschaeftsfuehrer.join('<br>'))
              .classed('org-tooltip--visible', true);
          })
          .on('mousemove', function (event) {
            var rect = container.getBoundingClientRect();
            tooltip
              .style('left', (event.clientX - rect.left + 14) + 'px')
              .style('top', (event.clientY - rect.top - 10) + 'px');
          })
          .on('mouseout', function () {
            tooltip.classed('org-tooltip--visible', false);
          });

        // Click: navigate to other firm pages
        node.filter(function (d) {
          return d.data.type === 'firma' && d.data.fnr && d.data.fnr !== fnr;
        })
          .style('cursor', 'pointer')
          .on('click', function (event, d) {
            window.location = '/firma/' + d.data.fnr;
          });
      }
    })();
