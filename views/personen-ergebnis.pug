extends layout

block content
  h1 Personensuche für "#{personenwortlaut}"

  if ergebnisse.length === 0
    div.error
      p Keine Personen gefunden.
      p Hinweis: Die Personensuche durchsucht nur Firmen, die bereits in unserer lokalen Datenbank gespeichert sind.
  else
    p.feedback-intro #{ergebnisse.length} Ergebnis#{ergebnisse.length === 1 ? '' : 'se'} gefunden.
    table.suche-table
      thead
        tr
          th Name
          th Funktion
          th Firma
          th Sitz
      tbody
        each r in ergebnisse
          tr.row-link(onclick=`window.location='/person?name=${encodeURIComponent(r.name)}'`)
            td
              a(href=`/person?name=${encodeURIComponent(r.name)}` onclick="event.stopPropagation()")= r.name
            td= r.rolle_text || '—'
            td
              a(href=`/firma/${r.company_fnr}` onclick="event.stopPropagation()")= r.company_name || r.company_fnr
              if r.rechtsform
                |
                small= r.rechtsform
            td= r.sitz || '—'

  a.back-fab(href="/" data-tooltip="Neue Suche")
    svg(xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round")
      polyline(points="15 18 9 12 15 6")

block scripts
  script.
    (function () {
      var btn = document.querySelector('.back-fab');
      if (btn && document.referrer && document.referrer.indexOf(location.host) !== -1) {
        btn.addEventListener('click', function (e) {
          e.preventDefault();
          history.back();
        });
      }
    })();
