extends layout

block content
  h1 Urkunden für #{fnr}

  if urkunden.length === 0
    p Keine Urkunden gefunden.
  else
    table.urkunden-table
      thead
        tr
          th Dokumentart
          th Stichtag / Datum
          th Eingereicht
          th Typ
          th Größe
          th
      tbody
        each u in urkunden
          tr
            td
              | #{u.dokumentart || '—'}
              if u.bemerkung
                br
                small= u.bemerkung
            td= u.stichtag || u.dokumentendatum || '—'
            td= u.eingereicht || '—'
            td
              span.badge(class=u.dateiendung === 'pdf' ? 'badge--active' : 'badge--history')
                = u.dateiendung.toUpperCase()
            td= u.groesseFormatiert || '—'
            td
              a.btn.hide-mobile(href=`/urkunde/download?key=${encodeURIComponent(u.key)}` target="_blank") Öffnen
              a.btn-icon.show-mobile(href=`/urkunde/download?key=${encodeURIComponent(u.key)}` target="_blank" title="Öffnen")
                svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round")
                  path(d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z")
                  circle(cx="12" cy="12" r="3")

  a.back-link(href=`/firma/${fnr}`) ← Zurück zur Firma
