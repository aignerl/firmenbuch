extends layout

block content
  h1 Suchergebnisse für "#{firmenwortlaut}"

  if ergebnisse.length === 0
    div.error
      p Keine Ergebnisse gefunden.
      p Tipps für die Suche:
      ul(style="margin: 8px 0 0 20px; line-height: 2")
        li Verwende <strong>*</strong> als Platzhalter am Anfang und/oder Ende, z.B. <strong>*energie*</strong>
        li Die API unterstützt kein Durchsuchen aller Firmen ohne Namensangabe — bitte mindestens einen Teil des Firmennamens eingeben
        li Rechtsform- und Bundesland-Filter funktionieren nur in Kombination mit einem Suchbegriff
  else
    table.suche-table
      thead
        tr
          th FNR
          th Name
          th Sitz
          th Rechtsform
          th Status
      tbody
        each e in ergebnisse
          tr.row-link(onclick=`window.location='/firma/${e.fnr}'`)
            td
              a(href=`/firma/${e.fnr}`)= e.fnr
            td= e.name
            td= e.sitz
            td= e.rechtsform
            td
              if e.status === 'gelöscht'
                span.badge.badge--deleted= e.status
              else if e.status === 'historisch'
                span.badge.badge--history= e.status
              else if e.status
                span.badge.badge--active= e.status

  a.back-fab(href="/" data-tooltip="Neue Suche")
    svg(xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round")
      polyline(points="15 18 9 12 15 6")
